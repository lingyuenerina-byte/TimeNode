{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeNode",
  "version": "0.1.0",
  "identifier": "com.lingy.timenode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
  {
    "title": "TimeNode",
    "width": 1231,
    "height": 910,
    "resizable": false,
    "fullscreen": false,
    "center": true
  }
     ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
